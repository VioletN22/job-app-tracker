{
  "manifest_version": 3,
  "name": "aplyd Autopilot",
  "short_name": "aplyd",
  "version": "1.1.0",
  "description": "Auto-fill job applications (LinkedIn Easy Apply + external ATS) from your aplyd profile. Learns as it goes; you review and submit.",
  "permissions": ["activeTab"],
  "host_permissions": [
    "http://127.0.0.1:17872/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "aplyd Autopilot"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "all_frames": false,
      "js": [
        "filler-core.js",
        "cover-studio.js",
        "adapters/linkedin.js",
        "adapters/greenhouse.js",
        "adapters/lever.js",
        "adapters/generic.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon-128.png"],
      "matches": ["https://*/*"]
    }
  ]
}
